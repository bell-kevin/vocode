ELEVENLABS_API_KEY=
ELEVENLABS_STT_MODEL_ID=scribe_v2_realtime
# ISO 639-1 (e.g. en). Set to auto to omit and let ElevenLabs auto-detect (may flip languages).
ELEVENLABS_STT_LANGUAGE=en
VOCODE_VOICE_STT_ENABLED=true
VOCODE_VOICE_VAD_THRESHOLD_MULTIPLIER=1.65
# PCM16 RMS floor for speech vs noise (per 20ms frame); lower = more sensitive if the meter says Quiet.
VOCODE_VOICE_VAD_MIN_ENERGY_FLOOR=100
VOCODE_VOICE_VAD_START_MS=60
VOCODE_VOICE_VAD_END_MS=750
VOCODE_VOICE_VAD_PREROLL_MS=320
# If committed_transcript never arrives after commit:true, flush deferred PCM after this many ms. 0 = wait indefinitely.
VOCODE_VOICE_STT_COMMIT_RESPONSE_TIMEOUT_MS=5000
VOCODE_VOICE_STREAM_CHUNK_MS=300
VOCODE_VOICE_STREAM_MIN_CHUNK_MS=200
VOCODE_VOICE_STREAM_MAX_CHUNK_MS=500
VOCODE_VOICE_STREAM_MAX_UTTERANCE_MS=4000

# Daemon-side transcript queueing (FIFO + timed coalescing)
VOCODE_DAEMON_VOICE_TRANSCRIPT_QUEUE_SIZE=10
VOCODE_DAEMON_VOICE_TRANSCRIPT_COALESCE_MS=750
VOCODE_DAEMON_VOICE_TRANSCRIPT_MAX_MERGE_JOBS=5
VOCODE_DAEMON_VOICE_TRANSCRIPT_MAX_MERGE_CHARS=6000
VOCODE_DAEMON_VOICE_MAX_PLANNER_TURNS=8
VOCODE_DAEMON_VOICE_MAX_INTENT_RETRIES=2
VOCODE_DAEMON_VOICE_MAX_CONTEXT_ROUNDS=2
VOCODE_DAEMON_VOICE_MAX_CONTEXT_BYTES=12000
VOCODE_DAEMON_VOICE_MAX_CONSECUTIVE_CONTEXT_REQUESTS=3

# Optional override for tree-sitter binary used by daemon symbol resolution.
# Extension auto-wires a provisioned binary path when this is unset.
# VOCODE_TREE_SITTER_BIN=C:\Dev\vocode\tools\tree-sitter\win32-x64\tree-sitter.exe

VOCODE_VOICE_VAD_DEBUG=false