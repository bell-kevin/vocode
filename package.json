{
  "name": "vocode",
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "description": "Root vocode monorepo",
  "scripts": {
    "prebuild": "pnpm codegen",
    "build": "turbo run build",
    "postinstall": "pnpm provision:ripgrep",
    "provision:ripgrep": "node scripts/dev/provision-ripgrep.mjs",
    "fix": "pnpm lint:fix && go fmt ./...",
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter @vocode/web dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format .",
    "format:write": "biome format --write .",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "codegen:ts": "node scripts/codegen/generate-protocol-ts.mjs && pnpm --filter @vocode/protocol build",
    "codegen:go": "node scripts/codegen/generate-protocol-go.mjs",
    "codegen": "pnpm codegen:ts && pnpm codegen:go",
    "setup-portaudio:win": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/dev/setup-portaudio.pnpm.ps1",
    "vscode:package": "pnpm --filter vocode vscode:package"
  },
  "devDependencies": {
    "@apidevtools/json-schema-ref-parser": "^15.3.1",
    "@biomejs/biome": "^2.4.8",
    "@vscode/ripgrep": "^1.15.14",
    "json-schema-to-typescript": "^15.0.4",

    "turbo": "^2.8.20"
  },
  "dependencies": {
    "tailwind": "^4.0.0",
    "vite": "^8.0.3"
  }
}
