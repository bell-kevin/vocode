{
  "name": "@vocode/vscode-extension",
  "displayName": "Vocode",
  "description": "Voice-driven coding assistant for VS Code",
  "version": "0.0.1",
  "private": true,
  "publisher": "our-publisher-id",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "AI"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "vocode.ping",
        "title": "Vocode: Ping Daemon"
      },
      {
        "command": "vocode.startVoice",
        "title": "Vocode: Start Voice"
      },
      {
        "command": "vocode.stopVoice",
        "title": "Vocode: Stop Voice"
      },
      {
        "command": "vocode.sendTranscript",
        "title": "Vocode: Send Transcript"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vocode",
          "title": "Vocode",
          "icon": "media/vocode-icon.svg"
        }
      ]
    },
    "views": {
      "vocode": [
        {
          "id": "vocode.transcriptPanel",
          "name": "Voice",
          "type": "webview",
          "contextualTitle": "Vocode"
        }
      ]
    },
    "configuration": {
      "title": "Vocode",
      "properties": {
        "vocode.voiceVadDebug": {
          "type": "boolean",
          "default": false,
          "description": "Forward VOCODE_VOICE_VAD_DEBUG=1 to the voice sidecar ([vocode-vad] lines on stderr)."
        },
        "vocode.voiceSidecarLogProtocol": {
          "type": "boolean",
          "default": false,
          "description": "Log every JSON line from the voice sidecar to Developer Tools (very noisy). Leave off to see stderr debug lines ([vocode-vad], [vocode-stt]) clearly."
        }
      }
    }
  },
  "scripts": {
    "prebuild": "pnpm --dir ../.. provision:tree-sitter",
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "test": "pnpm build && node --test \"dist/**/*.test.js\"",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@vocode/protocol": "workspace:*",
    "@types/node": "^22.15.0",
    "@types/vscode": "^1.110.0",
    "typescript": "^5.8.3"
  }
}
