{
  "name": "@vocode/vscode-extension",
  "displayName": "Vocode",
  "description": "Voice-driven coding assistant for VS Code",
  "version": "0.0.1",
  "private": true,
  "publisher": "our-publisher-id",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "AI"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "vocode.ping",
        "title": "Vocode: Ping Daemon"
      },
      {
        "command": "vocode.startVoice",
        "title": "Vocode: Start Voice"
      },
      {
        "command": "vocode.stopVoice",
        "title": "Vocode: Stop Voice"
      },
      {
        "command": "vocode.applyEdit",
        "title": "Vocode: Apply Edit"
      },
      {
        "command": "vocode.runCommand",
        "title": "Vocode: Run Command"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "test": "pnpm build && node --test \"dist/**/*.test.js\"",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@vocode/protocol": "workspace:*",
    "@types/node": "^22.15.0",
    "@types/vscode": "^1.110.0",
    "typescript": "^5.8.3"
  }
}
