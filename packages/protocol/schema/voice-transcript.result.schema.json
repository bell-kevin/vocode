{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vocoding.net/schemas/voice-transcript.result.schema.json",
  "title": "VoiceTranscriptResult",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "accepted": { "type": "boolean" },
    "summary": {
      "type": "string",
      "description": "Human-readable summary when the agent ends the loop (control_done); for host UI.",
      "maxLength": 8192
    },
    "directives": {
      "type": "array",
      "items": {
        "$ref": "./voice-transcript.directive.schema.json"
      }
    },
    "applyBatchId": {
      "type": "string",
      "description": "Correlates host apply reports with daemon-held intents; present when accepted and directives is non-empty."
    }
  },
  "required": ["accepted"]
}
