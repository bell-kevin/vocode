{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vocoding.net/schemas/voice-transcript.result.schema.json",
  "title": "VoiceTranscriptResult",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "accepted": { "type": "boolean" },
    "planError": {
      "type": "string",
      "description": "Set when the transcript was accepted but the model or plan validation failed before execution."
    },
    "steps": {
      "type": "array",
      "items": {
        "$ref": "./voice-transcript.step-result.schema.json"
      }
    }
  },
  "required": ["accepted"]
}
