{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vocoding.net/schemas/voice-transcript.directive.schema.json",
  "title": "VoiceTranscriptDirective",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "kind": {
      "type": "string",
      "enum": [
        "edit",
        "command",
        "navigate",
        "undo",
        "rename",
        "code_action",
        "format",
        "delete_file",
        "move_path",
        "create_folder"
      ]
    },
    "editDirective": {
      "$ref": "./edit-directive.schema.json"
    },
    "commandDirective": {
      "$ref": "./command-directive.schema.json"
    },
    "navigationDirective": {
      "$ref": "./navigation-directive.schema.json"
    },
    "undoDirective": {
      "$ref": "./undo-directive.schema.json"
    },
    "renameDirective": {
      "$ref": "./rename-directive.schema.json"
    },
    "codeActionDirective": {
      "$ref": "./code-action-directive.schema.json"
    },
    "formatDirective": {
      "$ref": "./format-directive.schema.json"
    },
    "deleteFileDirective": {
      "$ref": "./delete-file-directive.schema.json"
    },
    "movePathDirective": {
      "$ref": "./move-path-directive.schema.json"
    },
    "createFolderDirective": {
      "$ref": "./create-folder-directive.schema.json"
    }
  },
  "required": ["kind"]
}
