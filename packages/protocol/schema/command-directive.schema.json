{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vocoding.net/schemas/command-directive.schema.json",
  "title": "CommandDirective",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "command": { "type": "string" },
    "args": {
      "type": "array",
      "items": { "type": "string" }
    },
    "workingDirectory": {
      "type": "string",
      "description": "Optional absolute directory passed to spawn cwd; when set, the child process starts in this folder."
    },
    "timeoutMs": { "type": "integer" }
  },
  "required": ["command"]
}
