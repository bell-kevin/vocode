{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vocoding.net/schemas/host-get-document-symbols.result.schema.json",
  "title": "HostGetDocumentSymbolsResult",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "symbols": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "kind", "range", "selectionRange"],
        "properties": {
          "name": { "type": "string" },
          "kind": { "type": "string" },
          "range": {
            "type": "object",
            "additionalProperties": false,
            "required": ["startLine", "startChar", "endLine", "endChar"],
            "properties": {
              "startLine": { "type": "integer", "minimum": 0 },
              "startChar": { "type": "integer", "minimum": 0 },
              "endLine": { "type": "integer", "minimum": 0 },
              "endChar": { "type": "integer", "minimum": 0 }
            }
          },
          "selectionRange": {
            "type": "object",
            "additionalProperties": false,
            "required": ["startLine", "startChar", "endLine", "endChar"],
            "properties": {
              "startLine": { "type": "integer", "minimum": 0 },
              "startChar": { "type": "integer", "minimum": 0 },
              "endLine": { "type": "integer", "minimum": 0 },
              "endChar": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    }
  },
  "required": ["symbols"]
}
