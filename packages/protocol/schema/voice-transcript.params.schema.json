{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vocoding.net/schemas/voice-transcript.params.schema.json",
  "title": "VoiceTranscriptParams",
  "$defs": {
    "HostContext": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "text": {
          "type": "string",
          "description": "Committed transcript text (STT). Omitted when sending a controlRequest-only RPC."
        },
        "activeFile": {
          "type": "string",
          "description": "Absolute path of the active editor file; the daemon loads content (indexing / snapshot later)."
        },
        "workspaceRoot": {
          "type": "string",
          "description": "Absolute workspace folder when one is open; otherwise the host may send the active file's parent directory so relative paths still resolve (single-file windows)."
        },
        "workspaceFolderOpen": {
          "type": "boolean",
          "description": "True when vscode.workspace.workspaceFolders is non-empty. Used to gate file-selection / explorer voice flows (VS Code\u2013aligned: open a folder first)."
        },
        "focusedWorkspacePath": {
          "type": "string",
          "description": "Absolute path of the focused file or folder in the file-selection UI, when that flow is active."
        },
        "cursorPosition": {
          "type": "object",
          "description": "Caret in the active editor (LSP / VS Code Position). The daemon resolves the innermost symbol at this location using host-provided document symbols (LSP).",
          "additionalProperties": false,
          "required": ["line", "character"],
          "properties": {
            "line": {
              "type": "integer",
              "description": "0-based line index."
            },
            "character": {
              "type": "integer",
              "description": "0-based UTF-16 code unit offset within the line. Reserved for finer resolution; tag-based backend may use line only today."
            }
          }
        },
        "activeSelection": {
          "type": "object",
          "description": "Selection in the active editor (LSP / VS Code Range). When empty, start==end at cursor.",
          "additionalProperties": false,
          "required": ["startLine", "startChar", "endLine", "endChar"],
          "properties": {
            "startLine": {
              "type": "integer",
              "minimum": 0
            },
            "startChar": {
              "type": "integer",
              "minimum": 0
            },
            "endLine": {
              "type": "integer",
              "minimum": 0
            },
            "endChar": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "activeFileSymbols": {
          "type": "array",
          "description": "Document symbols for the active file from the host's LSP (vscode.executeDocumentSymbolProvider). Used for scope resolution; required for scope-first editing.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "kind", "range", "selectionRange"],
            "properties": {
              "name": {
                "type": "string"
              },
              "kind": {
                "type": "string"
              },
              "range": {
                "type": "object",
                "additionalProperties": false,
                "required": ["startLine", "startChar", "endLine", "endChar"],
                "properties": {
                  "startLine": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "startChar": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "endLine": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "endChar": {
                    "type": "integer",
                    "minimum": 0
                  }
                }
              },
              "selectionRange": {
                "type": "object",
                "additionalProperties": false,
                "required": ["startLine", "startChar", "endLine", "endChar"],
                "properties": {
                  "startLine": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "startChar": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "endLine": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "endChar": {
                    "type": "integer",
                    "minimum": 0
                  }
                }
              }
            }
          }
        },
        "contextSessionId": {
          "type": "string",
          "description": "Internal-only key for persisting Gathered between RPCs (host assigns; user never manages it). Omit for ephemeral gathered."
        },
        "controlRequest": {
          "type": "string",
          "enum": ["cancel_clarify", "cancel_selection", "cancel_file_selection"],
          "description": "Host UI control: cancel clarification, close workspace hit list, or close file hit list without spoken text."
        },
        "daemonConfig": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "sessionIdleResetMs": {
              "type": "integer",
              "description": "Overrides VOCODE_DAEMON_SESSION_IDLE_RESET_MS (0 disables idle eviction)."
            },
            "maxGatheredBytes": {
              "type": "integer",
              "description": "Overrides VOCODE_DAEMON_GATHERED_MAX_BYTES."
            },
            "maxGatheredExcerpts": {
              "type": "integer",
              "description": "Overrides VOCODE_DAEMON_GATHERED_MAX_EXCERPTS."
            }
          }
        }
      }
    },
    "AsControl": {
      "type": "object",
      "additionalProperties": false,
      "allOf": [
        {
          "$ref": "#/$defs/HostContext"
        },
        {
          "type": "object",
          "required": ["controlRequest"],
          "properties": {
            "controlRequest": {
              "type": "string",
              "enum": ["cancel_clarify", "cancel_selection", "cancel_file_selection"]
            }
          }
        }
      ]
    },
    "AsTranscript": {
      "type": "object",
      "additionalProperties": false,
      "allOf": [
        {
          "$ref": "#/$defs/HostContext"
        },
        {
          "type": "object",
          "required": ["text"],
          "properties": {
            "text": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    }
  },
  "oneOf": [
    {
      "$ref": "#/$defs/AsControl"
    },
    {
      "$ref": "#/$defs/AsTranscript"
    }
  ]
}
