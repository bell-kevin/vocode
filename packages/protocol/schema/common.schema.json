{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vocoding.net/schemas/common.schema.json",
  "$defs": {
    "Anchor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "before": { "type": "string" },
        "after": { "type": "string" }
      },
      "required": ["before", "after"]
    },
    "EditFailure": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "unsupported_instruction",
            "ambiguous_target",
            "missing_anchor",
            "validation_failed",
            "no_change_needed"
          ]
        },
        "message": { "type": "string" }
      },
      "required": ["code", "message"]
    }
  }
}
