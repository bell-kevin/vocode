{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "codegen",
      "type": "shell",
      "command": "pnpm codegen",
      "problemMatcher": []
    },
    {
      "label": "build:daemon",
      "type": "shell",
      "command": "pnpm --filter @vocode/daemon build",
      "problemMatcher": []
    },
    {
      "label": "build:voice",
      "type": "shell",
      "command": "pnpm --filter @vocode/voice build",
      "problemMatcher": []
    },
    {
      "label": "build:vscode-extension",
      "type": "shell",
      "command": "pnpm --filter ./apps/vscode-extension build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "build:native",
      "dependsOn": ["build:daemon", "build:voice"],
      "dependsOrder": "parallel"
    },
    {
      "label": "build:native-and-extension",
      "dependsOn": ["build:native", "build:vscode-extension"],
      "dependsOrder": "parallel"
    },
    {
      "label": "build:dev-host",
      "dependsOn": ["codegen", "build:native-and-extension"],
      "dependsOrder": "sequence"
    }
  ]
}
